{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -r -I{} sh -c 'prettier --write \"{}\" 2>/dev/null || true'"
          }
        ]
      }
    ]
  }
}
